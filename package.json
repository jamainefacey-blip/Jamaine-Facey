{
  "name": "edge-functions-examples",
  "description": "Explore a library of reference examples for learning about Edge Functions on Netlify.",
  "version": "1.0.0",
  "scripts": {
    "build": "echo 'Static site — no framework build required'",
    "preview:ai-lab": "npx serve tools/rehab-client/ai-lab -p 4444 --no-clipboard",
    "ai-lab:vst": "npx tsx ai-lab/runner/run-vst-analysis.ts",
    "ai-lab:vst:json": "npx tsx ai-lab/runner/run-vst-analysis.ts --json",
    "ai-lab:vst-fhi": "npx tsx ai-lab/runner/run-vst-fhi.ts",
    "ai-lab:run": "npx tsx ai-lab/runner/run-asset.ts"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "https-proxy-agent": "^5.0.1",
    "tsx": "^4.19.2"
  },
