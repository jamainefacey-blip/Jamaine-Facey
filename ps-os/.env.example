# PS-OS Environment Variables
# Copy this file to .env.local and fill in real values before starting the server.

# ─── REQUIRED FOR AVA (AI responses) ─────────────────────────────────────────
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ─── REQUIRED FOR STRIPE PAYWALL ─────────────────────────────────────────────
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
# or for test mode:
# STRIPE_SECRET_KEY=sk_test_...

# Public base URL used for Stripe success/cancel redirects
# Set to your deployed domain in production
NEXT_PUBLIC_BASE_URL=http://localhost:3001

# ─── OPTIONAL — RAISES GITHUB RATE LIMIT (60 → 5000 req/hr) ─────────────────
# Get from: https://github.com/settings/tokens (no scopes needed for public repos)
GITHUB_TOKEN=ghp_...

# ─── OPTIONAL — LEGACY AI PARSER (file ingestion fallback) ───────────────────
# Only required if using the original OpenAI-based file parser
OPENAI_API_KEY=sk-...

# ─── SERVER ──────────────────────────────────────────────────────────────────
PORT=3001
