# ─────────────────────────────────────────────────────────────────────────────
# VST Platform — Environment Variables
# Copy to .env.local (web) or .env (api) and fill in real values.
# NEVER commit real secrets to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── DATABASE ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://vst_user:password@localhost:5432/vst_db?schema=public"
REDIS_URL="redis://localhost:6379"

# ── AUTH (Clerk) ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_"
CLERK_SECRET_KEY="sk_test_"
CLERK_WEBHOOK_SECRET="whsec_"
# Clerk redirect URLs
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/dashboard"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/dashboard"

# ── PAYMENTS (Stripe) ─────────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_"
STRIPE_PUBLISHABLE_KEY="pk_test_"
STRIPE_WEBHOOK_SECRET="whsec_"
# Price IDs from Stripe dashboard
STRIPE_PRICE_PREMIUM_MONTHLY="price_"
STRIPE_PRICE_PREMIUM_ANNUAL="price_"
STRIPE_PRICE_ELITE_MONTHLY="price_"
STRIPE_PRICE_ELITE_ANNUAL="price_"

# ── NOTIFICATIONS (Twilio) ────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID="AC"
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER="+44"
TWILIO_MESSAGING_SERVICE_SID="MG"

# ── EMAIL (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY="re_"
EMAIL_FROM="noreply@voyagesmarttravel.com"

# ── FLIGHT SEARCH (Skyscanner) ────────────────────────────────────────────────
SKYSCANNER_API_KEY=""
SKYSCANNER_API_HOST="skyscanner-skyscanner-flight-search-v1.p.rapidapi.com"

# ── HOTEL SEARCH (Booking.com Affiliate) ──────────────────────────────────────
BOOKING_COM_AFFILIATE_ID=""
BOOKING_COM_API_KEY=""

# ── MAPS (Mapbox) ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_MAPBOX_TOKEN="pk."
MAPBOX_SECRET_TOKEN="sk."

# ── STORAGE (Cloudflare R2 / S3-compatible) ───────────────────────────────────
STORAGE_BUCKET="vst-uploads"
STORAGE_REGION="auto"
STORAGE_ENDPOINT="https://.r2.cloudflarestorage.com"
STORAGE_ACCESS_KEY_ID=""
STORAGE_SECRET_ACCESS_KEY=""
STORAGE_PUBLIC_URL="https://uploads.voyagesmarttravel.com"

# ── AUTOMATION (n8n) ──────────────────────────────────────────────────────────
N8N_WEBHOOK_BASE_URL="https://n8n.voyagesmarttravel.com/webhook"
N8N_API_KEY=""

# ── MONITORING (Sentry) ───────────────────────────────────────────────────────
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""

# ── APP ───────────────────────────────────────────────────────────────────────
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
API_URL="http://localhost:3001"
NEXT_PUBLIC_API_URL="http://localhost:3001"
API_SECRET="change-this-in-production-min-32-chars"

# ── FEATURE FLAGS ─────────────────────────────────────────────────────────────
FEATURE_COMMUNITY_ENABLED="false"
FEATURE_EXPLORER_MAP_ENABLED="false"
FEATURE_AI_RECOMMENDATIONS="false"

# ── SECURITY (Phase 5) ────────────────────────────────────────────────────────
# AES-256-GCM key for passport number encryption at rest.
# Generate: openssl rand -hex 32
# Must be exactly 64 hex characters (32 bytes). Never share or commit.
# Rotate: run a migration that decrypts all records with the old key and
#         re-encrypts with the new key before deploying the new key.
PASSPORT_ENCRYPTION_KEY=""

# CDN base URL for review/explorer media (used in upload URL generation)
CDN_BASE_URL="https://cdn.voyagesmarttravel.com"

# ── WEB PUSH / VAPID (Phase 5) ────────────────────────────────────────────────
# Generate VAPID keys once per application (not per deploy):
#   npx web-push generate-vapid-keys
# Public key is sent to browsers during push subscription registration.
# Private key stays server-side only — never expose in client code.
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:push@voyagesmarttravel.com"

# ── TRANSLATION (Phase 5) ─────────────────────────────────────────────────────
# Provider: stub (default, no key needed) | google | deepl | azure
# Phase 5: use 'stub'. Phase 6: set to 'google' or 'deepl' and add keys below.
TRANSLATION_PROVIDER="stub"
# GOOGLE_TRANSLATE_API_KEY=""
# DEEPL_API_KEY=""
# AZURE_TRANSLATOR_KEY=""
# AZURE_TRANSLATOR_REGION=""
