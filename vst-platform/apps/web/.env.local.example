# ── Resend email delivery ────────────────────────────────────────────────────
# Required for /api/leads to send notification emails on every submission.
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The email address that receives lead notifications (your business inbox)
VST_NOTIFY_EMAIL=leads@voyagesmarttravel.com

# The "From" address for outbound notifications.
# Must be from a domain verified in your Resend account.
# Defaults to Resend's shared sandbox domain if omitted (onboarding@resend.dev).
VST_FROM_EMAIL=VST Leads <noreply@voyagesmarttravel.com>
