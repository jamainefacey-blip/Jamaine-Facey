PORT=3000
NODE_ENV=development

# ── Coach Portal authentication ───────────────────────────────────────────────
# All POST / PUT / DELETE routes and GET /api/clients require this key.
# GET /api/clients/:slug is intentionally public (rehab module reads it).
# Generate a strong random key before deploying:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
COACH_API_KEY=change-me-before-deploying

# ── Stripe payment integration ────────────────────────────────────────────────
# STRIPE_SECRET_KEY — Stripe secret key for creating checkout sessions.
#   Find in Stripe Dashboard → Developers → API keys → Secret key.
#   Starts with sk_test_ (test) or sk_live_ (production).
STRIPE_SECRET_KEY=

# STRIPE_WEBHOOK_SECRET — Signing secret for verifying incoming webhook events.
#   Find in Stripe Dashboard → Developers → Webhooks → signing secret.
#   Starts with whsec_.  Leave blank to skip signature verification in development.
STRIPE_WEBHOOK_SECRET=

# ── CORS ─────────────────────────────────────────────────────────────────────
# In production: set to your frontend domain, e.g. https://yoursite.netlify.app
# In development: * allows all origins (fine for local use only)
CORS_ORIGIN=*
